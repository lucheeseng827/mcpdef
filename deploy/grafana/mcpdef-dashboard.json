{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping mcpdef /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "uid": "mcpdef-overview",
  "title": "mcpdef — gateway governance",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Upstreams", "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "mcpdef_upstreams", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "stat", "title": "Total calls", "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(mcpdef_tools_calls_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "stat", "title": "Denied", "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum(mcpdef_tools_calls_total{decision=\"deny\"})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "stat", "title": "Uptime (s)", "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "mcpdef_uptime_seconds", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "timeseries", "title": "Call rate by decision", "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (decision) (rate(mcpdef_tools_calls_total[1m]))", "legendFormat": "{{decision}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "timeseries", "title": "Denies by rule", "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (rule) (rate(mcpdef_tools_calls_total{decision=\"deny\"}[1m]))", "legendFormat": "{{rule}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "timeseries", "title": "Calls by server", "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [ { "refId": "A", "expr": "sum by (server) (rate(mcpdef_tools_calls_total[1m]))", "legendFormat": "{{server}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } } ]
    },
    {
      "type": "timeseries", "title": "Call latency p50 / p95 (ms)", "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(mcpdef_call_latency_ms_bucket[5m])))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(mcpdef_call_latency_ms_bucket[5m])))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    }
  ]
}
